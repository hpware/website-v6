---
import { ExternalLinkIcon } from "@lucide/astro";
interface Props {
    href: string;
    class?: string;
    [key: string]: any;
}
const { href, class: linkClass = "", ...attrs } = Astro.props;
---

<a
    href={href}
    {...attrs}
    class:list={[
        "relative inline-block no-underline",
        "after:absolute after:left-0 after:-bottom-0.5 after:h-px after:w-full",
        "after:bg-current after:content-['']",
        "after:origin-left after:scale-x-0",
        "after:transition-transform after:duration-300 after:ease-out",
        "hover:after:scale-x-100 focus-visible:after:scale-x-100 group",
        linkClass,
    ]}
>
    <div class="flex flex-row items-center">
        <slot />{
            (href.startsWith("https://") ||
                href.startsWith("http://") ||
                href.startsWith("mailto:")) && (
                <ExternalLinkIcon class="pl-1 w-4 h-4 group-hover:-rotate-5 group-hover:scale-110 transition-all duration-300" />
            )
        }
    </div>
</a>
