---
import Layout from "../layouts/Default.astro";
import { TriangleAlert } from "@lucide/astro";
---

<Layout title="404 找不到這個頁面">
    <div
        class="absolute inset-0 justify-center items-center flex flex-col text-center"
    >
        <TriangleAlert class="w-24 h-24 text-red-600" />
        <h1 class="text-4xl">404 找不到這個頁面</h1>
        <p>抱歉，您訪問的頁面不存在。</p>
        <p>請檢查網址是否正確，或返回<a href="/">首頁</a>繼續瀏覽。</p>
    </div>
</Layout>
