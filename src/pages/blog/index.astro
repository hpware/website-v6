---
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_DESCRIPTION } from "../../consts";
import Layout from "../../layouts/Default.astro";

const posts = (await getCollection("blog"))
    .filter((post) => post.data.status === "published")
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog" description={SITE_DESCRIPTION}>
    <div class="mx-auto max-w-3xl">
        <h1 class="text-2xl">貼文</h1>
        <ul class="mt-4 flex flex-col gap-4">
            {
                posts.map((post) => (
                    <li>
                        <a
                            href={`/blog/${post.id}/`}
                            class="block rounded-lg border border-accent p-4 transition-all duration-300 hover:bg-gray-500/10 dark:hover:bg-white/10"
                        >
                            <span class="text-xl">{post.data.title}</span>
                            <br />
                            <small>
                                發佈於{" "}
                                <FormattedDate date={post.data.pubDate} />
                            </small>
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</Layout>
