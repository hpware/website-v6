---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Default.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Prose from "../../components/Prose.astro";
import { CalendarSync, Calendar, ChevronLeft } from "@lucide/astro";
import Link from "../../components/Link.astro";

export async function getStaticPaths() {
    const posts = await getCollection(
        "blog",
        ({ data }) => data.status === "published",
    );
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}
type Props = CollectionEntry<"blog">;
const post = Astro.props;
const { Content } = await render(post);
const { heroImage, pubDate, updatedDate } = post.data;
---

<Layout title={post.data.title} description={post.data.description}>
    <article class="mx-auto max-w-3xl pb-3">
        <div class="hero-image">
            {
                heroImage && (
                    <Image width={1020} height={510} src={heroImage} alt="" />
                )
            }
        </div>
        <div>
            <div class="mb-1 pb-4">
                <Link
                    href="/blog/"
                    class="text-sm text-gray-500 dark:text-gray-400"
                >
                    <ChevronLeft class="w-5 h-5" />Back
                </Link>
                <h1 class="text-4xl font-bold">{post.data.title}</h1>
                <div class="mt-2 flex flex-row space-x-2">
                    <div
                        class="flex flex-row space-x-1 items-center text-center"
                    >
                        <Calendar class="w-5 h-5" />
                        <FormattedDate date={pubDate} />
                    </div>
                    {
                        updatedDate && (
                            <div class="flex flex-row space-x-1 items-center text-center">
                                <CalendarSync class="w-5 h-5" />
                                <FormattedDate date={updatedDate} />
                            </div>
                        )
                    }
                </div>
            </div>
            <hr class="mb-7 border-t border-border" />
            <Prose>
                <Content />
            </Prose>
        </div>
    </article>
</Layout>
